# Copy to .env and fill values. Never commit .env.
# Production/staging: inject the same variable names from your secrets manager at container startup.

# --- Supabase / PostgreSQL (auth-service, prescription-service, Flyway) ---
SUPABASE_DB_URL=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_MIGRATION_URL=

# --- Optional: Supabase REST (if used elsewhere) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- JWT (gateway / auth signing) ---
JWT_EC_PRIVATE_KEY_B64=
JWT_EC_PUBLIC_KEY_B64=
JWT_ACCESS_TOKEN_TTL=
JWT_REFRESH_TOKEN_TTL=

# --- Spring Cloud ---
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://discovery-service:8761/eureka
CONFIG_SERVER_URL=http://config-server:8888

# --- CORS ---
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Demo users (auth-service): bcrypt hashes are never in Git; enable seeding locally only ---
APP_DEMO_USERS_ENABLED=false
# Shared password for doctor@demo.com, pharmacist@demo.com, manager@demo.com when enabled:
DEMO_USER_PASSWORD=
# Optional per-role overrides:
# DEMO_DOCTOR_PASSWORD=
# DEMO_PHARMACIST_PASSWORD=
# DEMO_MANAGER_PASSWORD=

# --- Docker Hub ---
DOCKER_ORG=your-dockerhub-username

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080

# --- Notification (Twilio / SendGrid) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# --- Service URLs (docker-compose overrides) ---
AUTH_SERVICE_URL=http://localhost:8081
PRESCRIPTION_SERVICE_URL=http://localhost:8082
PHARMACY_SERVICE_URL=http://localhost:8083
PATIENT_SERVICE_URL=http://localhost:8084
INVENTORY_SERVICE_URL=http://localhost:8085
BILLING_SERVICE_URL=http://localhost:8086
ANALYTICS_SERVICE_URL=http://localhost:8087
